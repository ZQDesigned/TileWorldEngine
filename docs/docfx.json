{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "TileWorld.Engine/TileWorld.Engine.csproj",
            "TileWorld.Engine.Hosting.MonoGame/TileWorld.Engine.Hosting.MonoGame.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml",
          "articles/**.md",
          "api/**.md",
          "api/**.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "template": [
      "default",
      "modern"
    ],
    "output": "_site",
    "globalMetadata": {
      "_appTitle": "TileWorld Engine",
      "_appName": "TileWorld Engine",
      "_enableSearch": true,
      "_disableContribution": true
    }
  }
}
